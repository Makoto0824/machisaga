# テスト用「クーポン・回数をリセット」
# ローカル npm run dev では自動表示。本番は非表示（明示的に true のときのみ表示）
# NEXT_PUBLIC_ENABLE_TEST_TOOLS=true

# Supabase（チャンス・クーポンの永続化）
# Dashboard → Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 利用時のセットアップ:
# 1. SQL Editor で supabase/schema.sql を実行
# 2. Authentication → Providers → Anonymous Sign-Ins を ON
# 3. 本番公開前に supabase/rls-production.sql を実行
# 4. Vercel の Environment Variables にも同じ2つを設定
